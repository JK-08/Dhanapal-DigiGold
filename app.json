{
  "expo": {
    "name": "Dhanapal DigiGold",
    "slug": "dhanapal-scheme",
    "scheme": "dhanapal-scheme",
    "version": "1.0.3",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "light",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kiruba08.dhanapaldigold",
      "infoPlist": {
        "NSCameraUsageDescription": "This app uses the camera to scan barcodes and capture images.",
        "NSPhotoLibraryUsageDescription": "This app accesses your photo library to upload images.",
        "NSPhotoLibraryAddUsageDescription": "This app saves photos to your photo library.",
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "com.kiruba08.dhanapaldigold",
      "versionCode": 3,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.INTERNET",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "favicon": "./assets/logo.png"
    },
    "plugins": [
      "./plugins/withFirebaseNotificationChannel",
      "expo-font",
      "expo-asset",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "This app uses the camera to scan barcodes and capture images."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "This app accesses your photo library to upload images.",
          "cameraPermission": "This app uses the camera to take photos."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#FF971D",
          "defaultChannel": "default",
          "sounds": [],
          "mode": "production"
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24,
            "buildToolsVersion": "35.0.0",
            "newArchEnabled": true,
            "enableEdgeToEdge": true
          },
          "ios": {
            "deploymentTarget": "15.1",
            "newArchEnabled": true
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "@react-native-google-signin/google-signin",
      "@react-native-firebase/app",
      "@react-native-firebase/messaging",
      "expo-localization"
    ],
    "extra": {
      "apiBaseUrl": "https://scheme.dhanapaljewellery.com/api/v1",
      "eas": {
        "projectId": "0217705d-6a64-4e1d-8ca1-0e45194d4c44"
      }
    },
    "owner": "jk_08"
  }
}
